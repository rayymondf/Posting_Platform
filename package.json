{
  "name": "buildboard",
  "version": "1.0.0",
  "description": "BuildBoard — Engineering Project Collaboration Platform. Share projects, post build logs, recruit teammates.",
  "main": "server.js",
  "scripts": {
    "build": "vite build",
    "check:ports": "node scripts/check-dev-ports.js",
    "client:dev": "node node_modules/vite/bin/vite.js --host 0.0.0.0",
    "server:dev": "node node_modules/nodemon/bin/nodemon.js server.js",
    "start": "node server.js",
    "seed": "node scripts/seed.js",
    "predev": "npm run check:ports",
    "dev": "concurrently -k -n server,client \"node node_modules/nodemon/bin/nodemon.js server.js\" \"node node_modules/vite/bin/vite.js --host 0.0.0.0\"",
    "test": "npm run build && node --check server.js"
  },
  "keywords": [
    "engineering",
    "collaboration",
    "projects",
    "full-stack"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "lucide-react": "^0.475.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.2",
    "vite": "^8.0.11"
  }
}
